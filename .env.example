APP_NAME=World Echo API
APP_VERSION=1.0.0
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/v1
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/world_echo
PUBLIC_BASE_URL=http://localhost:8000
MOCK_OAUTH=true
MOCK_ASR=true
MOCK_VISION_PROMPT=true
MOCK_AUDIO_ANALYSIS=true
ENABLE_ESSENTIA=false
MOCK_MINIMAX=true
