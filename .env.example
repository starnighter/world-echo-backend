APP_NAME='World Echo API'
APP_VERSION=1.0.0
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/v1
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/world_echo
PUBLIC_BASE_URL=http://localhost:8000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/oauth/github/callback
QQ_CLIENT_ID=
QQ_CLIENT_SECRET=
QQ_REDIRECT_URI=http://localhost:8000/v1/auth/oauth/qq/callback
QQ_SCOPE=get_user_info
MOCK_OAUTH=true
VIVO_APP_KEY=
VIVO_ASR_WS_URL=ws://api-ai.vivo.com.cn/asr/v2
VIVO_LASR_BASE_URL=http://api-ai.vivo.com.cn/lasr
VIVO_SHORT_ASR_ENGINE_ID=shortasrinput
VIVO_LONG_ASR_ENGINE_ID=fileasrrecorder
VIVO_USER_ID=world-echo-backend
VIVO_APP_PACKAGE=world.echo.backend
VIVO_REALTIME_MIN_SECONDS=1.0
VIVO_REALTIME_SILENCE_RMS_THRESHOLD=150.0
VIVO_REALTIME_NOISE_ZCR_THRESHOLD=0.35
VIVO_SHORT_ASR_BUSINESS_INFO={"scenes_pkg":"world.echo.backend","editor_type":"3","pro_id":"world-echo-backend"}
MOCK_ASR=true
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Qwen/Qwen3-VL-32B-Instruct
MOCK_VISION_PROMPT=true
MOCK_AUDIO_ANALYSIS=true
ENABLE_ESSENTIA=false
MODELS_DIR=app/models
MINIMAX_API_URL=https://api.minimaxi.com/v1/music_generation
MINIMAX_API_KEY=
MOCK_MINIMAX=true
